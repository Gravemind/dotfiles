#!/bin/bash
#
# usage: create-vfat-img output.img file_or_dir [file_or_dir...]
#
# Creates an image file output.img, containing a FAT32, containing the given files.
#
# Uses udisks, so it doesn't need sudo/root.
#

set -euo pipefail

log() { echo "create-vfat-img: $*" >&2; }
die() { log "error: $*"; exit 1; }
run() { local c; c="$(printf ' %q' "$@")"; log "+$c"; "$@" || die "command failed ($?):$c"; }

usage="$0 output.img file_or_dir [file_or_dir...]"

for arg in "$@"
do
    case "$arg"
    in
        -h|--help)
            echo "usage: $usage"
            exit 0
            ;;
    esac
done

image="$1"
[[ "$image" = *.img ]] || die "output image should be a .img: $image"
shift
inputs=("$@")
[[ "${#inputs[@]}" -gt 0 ]] || die "missing input files image argument"

# FIXME: we should use --apparent-size (--bytes) and correctly compute overhead
size="$(run du -B1 --total "${inputs[@]}" | tail -n1 | cut -f1)"
size="$((size + 0))"
[[ "$size" -gt 1 ]] || die "unexpected input file size: $size"

mib=$((1024 * 1024))

image_size=$size

# Add overhead for FS metadata
# FIXME: overhead must depend on number of files/dirs/clusters
overhead=$((4 * mib))
image_size=$((image_size + overhead))

# FAT32 requires a minimum size, or else we get:
#   WARNING: Number of clusters for 32 bit FAT is less then suggested minimum.
# https://en.wikipedia.org/wiki/Design_of_the_FAT_file_system#Size_limits
# https://github.com/dosfstools/dosfstools/blob/289a48b9cb5b3c589391d28aa2515c325c932c7a/src/mkfs.fat.c#L980
# Wiki says 33,548,800, but it's missing metadata, so make it 36 MiB...
min=$((33 * mib))
image_size="$(( image_size < min ? min : image_size ))"

# Align size
align=$((4 * mib))
image_size="$(( ((image_size + align - 1) / align) * align ))"

log "input size: ${size} ($((size / mib))MiB)"
log "image size: ${image_size} ($((image_size / mib))MiB)"

run dd if=/dev/zero of="$image" bs=$mib count=$((image_size / mib)) status=none

run mkfs.vfat -F 32 -n MYIMAGE "$image"

loop=""
mount=""

atexit_teardown() {
    set +e
    if [[ -n "$loop" ]]
    then
        log "(exit teardown...)"
        if [[ -n "$mount" ]]
        then
            run udisksctl unmount -b "$loop" || true
            mount=""
        fi
        run udisksctl loop-delete -b "$loop" || true
        loop=""
        # run losetup -l
    fi
}

trap "atexit_teardown" EXIT

out="$(run udisksctl loop-setup -f "$image")"
loop="$(perl <<<"$out" -ne 's/^Mapped file .* as (\/dev\/loop\d+)\.?$/$1/ && print')"
[[ -n "$loop" && -b "$loop" ]] || die "unexpected udisksctl loop-setup output: $out"
log "loop: $loop"

out="$(run udisksctl mount -b "$loop")"
mount="$(perl <<<"$out" -ne 's/^Mounted .* at (\/run\/.*)$/$1/ && print')"
[[ -n "$mount" && -d "$mount" ]] || die "unexpected udisksctl loop-setup output: $out"
log "mount: $mount"

run cp -r -t "$mount" "${inputs[@]}"

if command -v tree &>/dev/null; then
    run tree "$mount"
else
    run ls -la "$mount"
fi

atexit_teardown

log ""
log "Done: $image"
log ""
